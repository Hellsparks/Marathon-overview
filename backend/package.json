{
  "name": "marathon-backend",
  "version": "1.3.0",
  "description": "Klipper fleet manager backend",
  "main": "src/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "SWATCH_SERVICE_URL=http://localhost:7321 nodemon --ignore data/ src/index.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 10000
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "mqtt": "^5.15.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
